  "keyFeatures": [
    "Rich text editor with Tiptap for creating and editing posts",
    "Multi-tenant workspaces with role-based access control",
    "REST API for fetching content programmatically",
    "Content organization with categories, tags, and authors",
    "Media management with Cloudflare R2 storage",
    "Webhook delivery system for real-time notifications",
    "API key management with scopes and rate limiting",
    "Usage analytics and tracking"
  ],
  "publicApiSurface": [
    "GET /v1/posts - List and fetch posts",
    "GET /v1/posts/:slug - Get post by slug",
    "GET /v1/categories - List categories",
    "GET /v1/categories/:slug - Get category by slug",
    "GET /v1/tags - List tags",
    "GET /v1/tags/:slug - Get tag by slug",
    "GET /v1/authors - List authors",
    "GET /v1/authors/:slug - Get author by slug",
    "POST /v1/cache/invalidate - Invalidate cache"
  ]
